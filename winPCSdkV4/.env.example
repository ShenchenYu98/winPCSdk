# Upstream test environment used by the local Vite proxy.
SKILL_PROXY_TARGET_HTTP=https://your-test-host.example.com
SKILL_PROXY_TARGET_WS=wss://your-test-host.example.com
SKILL_PROXY_COOKIE=userId=1

# Browser-side SDK endpoints. Keep these pointed at the local Vite dev server.
VITE_SKILL_SERVER_BASE_URL=http://localhost:5173
VITE_SKILL_SERVER_WS_URL=ws://localhost:5173/ws/skill/stream
