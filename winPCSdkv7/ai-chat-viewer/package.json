{
  "name": "ai-chat-viewer",
  "version": "1.0.0",
  "description": "AI 问答展示前端项目 - 支持网页运行和组件导出",
  "main": "dist/lib/index.js",
  "module": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "files": [
    "dist/lib"
  ],
  "scripts": {
    "dev": "webpack serve --mode development --open",
    "build": "webpack --mode production",
    "build:lib": "webpack --config webpack.lib.config.js --mode production && tsc --emitDeclarationOnly --declaration --outDir dist",
    "build:all": "npm run build && npm run build:lib",
    "build:require-demo": "npm run build:lib && webpack --config example/require-demo/webpack.config.js --mode production",
    "serve:require-demo": "webpack serve --config example/require-demo/webpack.config.js --mode development --open",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "keywords": [
    "react",
    "ai",
    "chat",
    "viewer",
    "component"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "core-js": "^3.48.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^6.10.0",
    "eslint": "^8.57.0",
    "html-webpack-plugin": "^5.6.0",
    "less": "^4.5.1",
    "less-loader": "^12.3.1",
    "style-loader": "^3.3.4",
    "typescript": "^5.4.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.0"
  },
  "browserslist": [
    ">0.5%",
    "last 2 versions",
    "not dead"
  ]
}
